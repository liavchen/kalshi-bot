# Kalshi API credentials
# Get these from https://kalshi.com/account/api (or demo: https://demo-api.kalshi.co)
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Environment: "demo" or "prod"
KALSHI_ENV=demo

# Sports Odds API (https://the-odds-api.com — free tier available)
ODDS_API_KEY=your-odds-api-key-here

# Risk limits
MAX_POSITION_USD=50
MAX_DAILY_LOSS_USD=100
EDGE_THRESHOLD=0.04
